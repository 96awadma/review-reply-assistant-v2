# ─────────────────────────────────────────────────────────────
# Review Reply Assistant v2 — environment variables
# Copy this file to `.env.local` and fill in real values.
# NEVER commit `.env.local`. Only `NEXT_PUBLIC_*` values reach the browser.
# ─────────────────────────────────────────────────────────────

# ── Supabase (added in Phase 2) ──────────────────────────────
# From: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only service role key (used by server routes; NOT public)
SUPABASE_SERVICE_ROLE_KEY=

# ── Google OAuth (added in Phase 3) ──────────────────────────
# From: Google Cloud Console → APIs & Services → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# The redirect URI must EXACTLY match one registered in Google Cloud.
# Production (recommended):
#   https://review-reply-assistant-v2.vercel.app/api/auth/google/callback
# Local (secondary):
#   http://localhost:3000/api/auth/google/callback
GOOGLE_REDIRECT_URI=https://review-reply-assistant-v2.vercel.app/api/auth/google/callback

# ── Token encryption (added in Phase 3) ──────────────────────
# 32-byte key (base64) used to encrypt stored Google tokens at rest.
# Generate with:  openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=

# ── App URL (used to build absolute OAuth redirects) ─────────
# Local:      http://localhost:3000
# Production: https://review-reply-assistant-v2.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000
